# --- tmux-ronin configuration ---
# Copy to .env and edit. All values are optional; sane defaults below.

# Port to listen on.
PORT=3006

# Bind address. Leave UNSET to auto-bind to the tailnet IP (`tailscale ip -4`),
# which keeps the server reachable only on your tailnet (recommended).
#   127.0.0.1  -> local only (e.g. behind your own reverse proxy)
#   0.0.0.0    -> ALL interfaces. On a public/cloud host this can expose a live
#                 shell to the internet if a firewall port is open. Avoid.
#BIND=100.x.y.z

# Optional HTTP Basic auth gate. Set BOTH to require a username + password.
# Strongly recommended if you ever expose this publicly (e.g. a reverse proxy).
#GRID_USER=admin
#GRID_PASS=change-me

# tmux window-size policy for browser viewers attached alongside another client:
#   latest   -> the window follows the most-recently-active client (default)
#   largest  -> stays at the largest client's size; small tiles show a viewport
#   smallest -> shrinks to the smallest client (can shrink another client)
#   manual   -> fixed; ignores clients
TMUX_WINDOW_SIZE=latest

# Mouse mode on browser viewer sessions.
#   on  -> trackpad/wheel scrolls the tmux scrollback (the conversation). (default)
#   off -> wheel is translated to Up/Down arrows (recalls prior prompt entries).
# Keyboard Up/Down always does history regardless of this setting.
TMUX_MOUSE=on
